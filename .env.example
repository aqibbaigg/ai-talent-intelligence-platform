# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/talent_db
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/talent_db

# ── App ───────────────────────────────────────────────────────────
APP_NAME="AI Talent Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── Embedding model ───────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── File upload ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ── LLM ───────────────────────────────────────────────────────────
OPENAI_API_KEY=your-key-here
GEMINI_API_KEY=
